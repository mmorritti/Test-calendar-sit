@page
@model CalendarDemo.Pages.IndexModel
@{
    ViewData["Title"] = "Calendario Eventi";
}

<style>
    /* ── BOTTONI FULLCALENDAR ── */

    body {
        background-color: #F2F1E3 !important;
        overflow-y: auto;
    /* Opzionale: previene lo scatto della pagina quando appare la barra */
    scrollbar-gutter: stable;
    }
    .fc-button-primary {
        background-color: #2D292D !important;
        border-color: #2D292D !important;
        color: white !important;
    }

        .fc-button-primary:hover {
            background-color: #4a454a !important;
            border-color: #4a454a !important;
        }

        .fc-button-primary:active,
        .fc-button-primary:focus,
        .fc-button-primary:not(:disabled):active,
        .fc-button-primary.fc-button-active {
            background-color: #767476 !important;
            border-color: #767476 !important;
            box-shadow: none !important;
        }

    .fc-event {
        cursor: pointer;
        border-radius: 6px !important;
    }

    /* ── BOTTONE + NUOVO EVENTO ── */
    .btn-primary {
        background-color: #2D292D !important;
        border-color: #2D292D !important;
        color: white !important;
    }

        .btn-primary:hover {
            background-color: #4a454a !important;
            border-color: #4a454a !important;
        }

        .btn-primary:active,
        .btn-primary:focus,
        .btn-primary:not(:disabled):active {
            background-color: #767476 !important;
            border-color: #767476 !important;
            box-shadow: none !important;
        }

    /* giorni della settimana (dom, lun, mar...) */
    .fc-col-header-cell-cushion {
        color: #2D292D !important;
        text-decoration: none !important;
        font-weight: 600;
    }

    /* numeri dei giorni */
    .fc-daygrid-day-number {
        color: #2D292D !important;
        text-decoration: none !important;
    }

    /* giorno corrente evidenziato — sfondo coerente */
    .fc-day-today {
        background-color: rgba(45, 41, 45, 0.06) !important;
    }

    /* giorni del mese precedente/successivo più sbiaditi */
    .fc-day-other .fc-daygrid-day-number {
        color: #a09da0 !important;
    }

    /* titolo marzo 2026 */
    .fc-toolbar-title {
        color: #2D292D !important;
        font-weight: 700 !important;
    }


</style>

<div class="container mt-4">

    <!-- HEADER -->
    <div class="d-flex justify-content-between align-items-center mb-3">
        <h3>📅 Calendario Eventi</h3>
        @* <button class="btn btn-primary" onclick="openCreateModal()">+ Nuovo Evento</button> *@
    </div>

    <!-- BARRA DI RICERCA -->
    <div class="row justify-content-center mb-2 mt-2">
        <div class="col-md-8">

            <div class="d-flex align-items-center bg-white border rounded-pill shadow-sm px-3 py-2 mb-3" style="border-color: #dee2e6 !important;">

                <span class="text-muted pe-2 border-0 bg-transparent fs-5">🔍</span>

                <input type="text"
                       id="search-input"
                       class="form-control border-0 shadow-none p-0 bg-transparent"
                       style="font-size: 1rem;"
                       placeholder="Cerca eventi o descrizione..."
                       oninput="applyFilters()" />

                <button class="btn btn-link text-muted p-0 text-decoration-none px-2 fs-5"
                        onclick="clearFilters()"
                        title="Svuota ricerca"
                        style="opacity: 0.6;">
                    ✕
                </button>

                <div style="width: 1px; height: 24px; background-color: #dee2e6; margin: auto 10px;"></div>

                <div class="dropdown d-flex align-items-center">
                    <button class="btn btn-link text-dark text-decoration-none p-0 fw-medium d-flex align-items-center gap-1"
                            type="button"
                            id="regionDropdown"
                            data-bs-toggle="dropdown"
                            data-bs-auto-close="outside"
                            aria-expanded="false"
                            style="white-space: nowrap;">
                        <span class="fs-5">📍</span> <span class="d-none d-sm-inline">Regioni</span>
                    </button>
                    <ul class="dropdown-menu dropdown-menu-end shadow-lg border-0 mt-3 rounded-3" aria-labelledby="regionDropdown" id="region-dropdown-list">
                    </ul>
                </div>
            </div>

            <div id="region-tags" class="d-flex flex-wrap gap-2 px-3"></div>

        </div>
    </div>
    <!-- CALENDARIO -->
    <div class="card shadow-sm p-3">
        <div id="calendar"></div>
    </div>

</div>

<!-- ─── MODAL CREA / MODIFICA ─── -->
<div class="modal fade" id="formModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="modalTitle">Nuovo Evento</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">

                <div class="mb-3">
                    <label class="form-label fw-semibold">Titolo *</label>
                    <input type="text" class="form-control" id="f-title" placeholder="Es. Riunione team..." />
                </div>

                <div class="row">
                    <div class="col mb-3">
                        <label class="form-label fw-semibold">Data inizio *</label>
                        <input type="datetime-local" class="form-control" id="f-start" />
                    </div>
                    <div class="col mb-3">
                        <label class="form-label fw-semibold">Data fine</label>
                        <input type="datetime-local" class="form-control" id="f-end" />
                    </div>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Colore</label>
                    <select class="form-select" id="f-color">
                        <option value="#3788d8">🔵 Blu</option>
                        <option value="#e74c3c">🔴 Rosso</option>
                        <option value="#2ecc71">🟢 Verde</option>
                        <option value="#f39c12">🟡 Giallo</option>
                        <option value="#9b59b6">🟣 Viola</option>
                    </select>
                </div>

                <div class="mb-3">
                    <label class="form-label fw-semibold">Descrizione</label>
                    <textarea class="form-control" id="f-description" rows="3" placeholder="Note aggiuntive..."></textarea>
                </div>

            </div>
            <div class="modal-footer">
                <button class="btn btn-danger me-auto" id="btnDelete" style="display:none" onclick="deleteEvent()">🗑 Elimina</button>
                <button class="btn btn-secondary" data-bs-dismiss="modal">Annulla</button>
                <button class="btn btn-primary" onclick="saveEvent()">💾 Salva</button>
            </div>
        </div>
    </div>
</div>

<!-- ─── MODAL DETTAGLIO ─── -->
<div class="modal fade" id="detailModal" tabindex="-1">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title" id="detail-title"></h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
            </div>
            <div class="modal-body">
                <p class="text-muted mb-1" id="detail-date"></p>
                <p class="fw-bold mb-3 text-primary" id="detail-location"></p>

                <p id="detail-desc"></p>
            </div>
            <div class="modal-footer">
                <button class="btn btn-secondary" data-bs-dismiss="modal">Chiudi</button>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script src="~/js/calendar.js" asp-append-version="true"></script>
}